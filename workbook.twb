      <column caption='Inventory Turnover' datatype='real' name='[Calculation_0328268144594947]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([cogs]/[avg_inventory])' />
      </column>
      <column caption='Inventory' datatype='real' name='[Calculation_0328268145000452]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([inventory])' />
      </column>
      <column caption='Average Inventory' datatype='real' name='[Calculation_0328268145197061]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([avg_inventory])' />
      </column>
      <column caption='Inventory-to-Sales' datatype='real' name='[Calculation_0328268145340422]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([avg_inventory]/[sales])' />
      </column>
      <column caption='daysininventrory' datatype='real' name='[Calculation_0660873664950275]' role='measure' type='quantitative'>
